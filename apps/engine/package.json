{
  "name": "@beerengineer/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "beerengineer": "./bin/beerengineer.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/api/server.ts",
    "start:api": "tsx src/api/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx test/*.test.ts",
    "coverage": "c8 --reporter=lcov --reporter=text-summary --report-dir=../../coverage/engine node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@openai/codex-sdk": "^0.125.0",
    "better-sqlite3": "^11.10.0",
    "env-paths": "^4.0.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
