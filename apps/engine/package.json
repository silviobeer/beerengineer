{
  "name": "@beerengineer/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "beerengineer": "./bin/beerengineer.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/api/server.ts",
    "start:api": "tsx src/api/server.ts",
    "generate:item-actions-fixture": "tsx scripts/generateItemActionsFixture.ts",
    "check:item-actions-fixture": "tsx scripts/generateItemActionsFixture.ts --check",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:all",
    "test:all": "node ../../scripts/run-engine-tests.mjs all",
    "test:unit": "node ../../scripts/run-engine-tests.mjs unit",
    "test:integration": "node ../../scripts/run-engine-tests.mjs integration",
    "test:file": "node --test --import tsx",
    "test:managed-install": "node ../../scripts/run-engine-tests.mjs managed-install",
    "coverage": "npm run coverage:sonar",
    "coverage:sonar": "c8 --exclude src/llm/hosted/providers/claudeSdk.ts --exclude src/llm/hosted/providers/codexSdk.ts --exclude src/llm/hosted/providers/_sdkSession.ts --reporter=lcov --reporter=text-summary --report-dir=../../coverage/engine node ../../scripts/run-engine-tests.mjs sonar-coverage"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@openai/codex-sdk": "^0.125.0",
    "better-sqlite3": "^11.10.0",
    "env-paths": "^4.0.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
