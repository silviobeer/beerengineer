{
  "name": "beerengineer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:engine": "npm run dev --workspace=@beerengineer/engine",
    "dev:ui": "npm run dev --workspace=@beerengineer/ui -- --hostname 0.0.0.0 --port 3100",
    "start:api": "npm run start:api --workspace=@beerengineer/engine",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:all": "npm run test:all --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "coverage": "npm run coverage:sonar",
    "coverage:sonar": "rm -rf coverage && npm run coverage:sonar --workspaces --if-present && node scripts/normalize-lcov-paths.mjs"
  }
}
