{
  "name": "beerengineer",
  "version": "0.1.0",
  "private": true,
  "description": "CLI-first workflow engine for staged agent-driven product development.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli/main.ts",
    "review": "coderabbit review --config coderabbit.md",
    "review:agent": "coderabbit review --agent --config coderabbit.md",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "db:migrate": "tsx src/persistence/migrate.ts",
    "db:check": "tsx src/persistence/check-db.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "commander": "^14.0.1",
    "drizzle-orm": "^0.44.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.37.0",
    "sonar-scanner": "^3.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
